// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String    @id @default(cuid())
  email    String    @unique
  password String
  receipts Receipt[]
}

model Receipt {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  amount      Float
  fuelType    String
  stationName String
  date        DateTime @default(now())
  imageUrl    String?
  isManual    Boolean  @default(true)
}

model Station {
  id               String   @id @default(cuid())
  externalId       Int      // ID_pumpa from API
  name             String
  namePump         String
  color            String
  updatedAt        String
  currency         String
  owner            String
  operator         String
  addressMunicipality          String
  addressStreet    String
  lat              Float
  lon              Float
  price            Float
  fuelType         String
  lastUpdated      DateTime @default(now())

  @@unique([externalId, fuelType]) // A station has one price per fuel type
  @@index([lat, lon])
}